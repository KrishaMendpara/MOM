@model List<MeetingsModel>
<div class="pagetitle">
    <h1>Meetings List</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Meetings" asp-action="MeetingsList">Home</a></li>
            <li class="breadcrumb-item active">Meetings List</li>
        </ol>
    </nav>
</div><!-- End Page Title -->
@* Success Message *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Error Message *@
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<section class="section">
    <div class="row">
        <div class="col-lg-12">

            <a class="btn btn-primary mb-3">
                <i class="bi bi-plus-circle"></i> Schedule Meeting
            </a>

            <a class="btn btn-success mb-3">
                <i class="bi bi-file-earmark-excel"></i> Export
            </a>

            <form class="mb-5">
                <div style="background: linear-gradient(90deg, #6f75e6 0%, #7b57c2 100%);
                            padding: 14px 20px;
                            border-radius: 10px 10px 0 0;
                            color: #fff;
                            display: flex;
                            align-items: center;
                            gap: 10px;
">
                    <i class="bi bi-funnel" style="font-size:18px;"></i>
                    <h5 style="margin:0;font-weight:600;font-size:16px;">
                        Search & Filters
                    </h5>
                </div>


                <div class="row mb-3">

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Meeting Type</label>
                        <div class="input-group">
                            <select class="form-select">
                                <option selected>All Types</option>
                                <option>Exam</option>
                                <option>Student</option>
                                <option>Review</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Department</label>
                        <div class="input-group">
                            <select class="form-select">
                                <option selected>All Departments</option>
                                <option>B.Tech</option>
                                <option>Bsc</option>
                                <option>BCA</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Venue</label>
                        <div class="input-group">
                            <select class="form-select">
                                <option selected>All Venues</option>
                                <option>Staff Room</option>
                                <option>Meeting Room</option>
                                <option>Audi</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Search</label>
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Search meetings...">
                            <span class="input-group-text bg-white">
                                <i class="bi bi-search"></i>
                            </span>
                        </div>
                    </div>

                </div>

                <div class="row align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Start Date</label>
                        <input type="date" class="form-control">
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">End Date</label>
                        <input type="date" class="form-control">
                    </div>

                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-funnel me-1"></i> Apply Filters
                        </button>
                    </div>

                    <div class="col-md-3">
                        <a href="#" class="btn btn-link text-decoration-none">
                            <i class="bi bi-arrow-clockwise"></i> Clear
                        </a>
                    </div>
                </div>
            </form>

            <div class="card">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0"><i class="bi bi-building me-2"></i>Scheduled Meetings</h5>

                        <a href="@Url.Action("MeetingsAddEdit", "Meetings")" class="btn btn-primary">
                            <i class="bi bi-plus-lg"></i> Add Meeting
                        </a>
                    </div>
                    <form method="post" asp-action="MeetingsList" asp-controller="Meetings" class="mb-3">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-4">
                                <label for="SearchText" class="form-label">Search by Meeting Description</label>
                                <input type="text" name="SearchText" id="SearchText" class="form-control"
                                       placeholder="Enter Meeting Description" value="@ViewBag.SearchText" />
                            </div>
                            <div class="col-md-4">
                                <button type="submit" class="btn btn-info">
                                    <i class="fas fa-search"></i> Search
                                </button>
                                <a asp-controller="Meetings" asp-action="MeetingsList" class="btn btn-secondary ms-2">
                                    <i class="fas fa-undo"></i> Reset
                                </a>
                            </div>
                        </div>
                    </form>

                     @if (Model != null && Model.Count > 0)
                    {
                        <table class="table ">
                            <thead>
                                <tr>

                                    <th>MeetingTypeID</th>
                                    <th>MeetingDate</th>
                                    <th>MeetingDescription</th>
                                    <th>DocumentPath </th>
                                    <th>IsCancelled</th>
                                    <th>CancellationReason</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach(var meetings in Model)
                                {
                                    <tr>
                                        <td>@meetings.MeetingTypeID</td>
                                        <td>@meetings.MeetingDate</td>
                                        <td>@meetings.MeetingDescription</td>
                                        <td>@meetings.DocumentPath</td>
                          
                                        
                                        <td>
                                            @meetings.IsCancelled  
                                        </td>
                                        <td>@meetings.CancellationReason</td>
                                        <td class="d-flex gap-2 align-items-center">

                                            <!-- Edit Button -->
                                            <a asp-controller="Meetings" asp-action="MeetingsAddEdit" asp-route-id="@meetings.MeetingID"
                                               title="Edit"
                                               style="
                                                       width:36px;
                                                       height:36px;
                                                       border:1.5px solid #0d6efd;
                                                       border-radius:6px;
                                                       display:flex;
                                                       align-items:center;
                                                       justify-content:center;
                                                       color:#0d6efd;
                                                       text-decoration:none;
               ">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <!-- Delete Button -->
                                            <a asp-controller="Meetings" asp-action="Delete" asp-route-id="@meetings.MeetingID"
                                               title="Delete"
                                               style="
                                                       width:36px;
                                                       height:36px;
                                                       border:1.5px solid #dc3545;
                                                       border-radius:6px;
                                                       display:flex;
                                                       align-items:center;
                                                       justify-content:center;
                                                       color:#dc3545;
                                                       text-decoration:none;
               ">
                                                <i class="bi bi-trash"></i>
                                            </a>

                                        </td>
                                    </tr>
                                }
                            </tbody>
                                </table>
                    }

                    else
                    {
                        <div class="alert alert-info">
                            No departments found. Click "Add New Department" to create one.
                        </div>
                    }

                    <!-- End Table with stripped rows -->
                    <!-- ✅ SCRIPT MUST BE WRITTEN ONLY ONCE -->
                    <script>
                        function toggleAttendance(btn) {
                            if (btn.innerText === "Present") {
                                btn.innerText = "Absent";
                                btn.classList.remove("btn-success");
                                btn.classList.add("btn-danger");
                            } else {
                                btn.innerText = "Present";
                                btn.classList.remove("btn-danger");
                                btn.classList.add("btn-success");
                            }
                        }
                    </script>
                </div>
            </div>

        </div>
    </div>
</section>